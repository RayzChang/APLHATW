# FinMind API（必填，未設定則無法取得個股/加權指數行情）
# 至 https://finmindtrade.com/ 註冊並取得 API Token 後貼上
FINMIND_TOKEN=

# Gemini API Key (Phase 3 AI Agent)
# 至 Google AI Studio 申請 API Key
GEMINI_API_KEY=

# LINE Notify Token (Phase 4 交易警報)
# 至 https://notify-bot.line.me/ 申請
LINE_NOTIFY_TOKEN=

# 模擬交易初始資金（台幣）
SIMULATION_INITIAL_BALANCE=1000000

# 儀表板帳密
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme

# API 埠
API_PORT=8888
